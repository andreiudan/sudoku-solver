<Page x:Class="SudokuSolver.Pages.Game"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SudokuSolver.Pages"
      xmlns:n="clr-namespace:SudokuSolver.UserControls"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Game">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="194*"/>
            <RowDefinition Height="31*"/>
        </Grid.RowDefinitions>

        <!-- GameGrid -->
        <DataGrid Margin="12" HeadersVisibility="None" Name="dataGridGame">
            <DataGrid.Columns/>


        </DataGrid>
        
        <!-- Buttons -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <n:NavButton x:Name="btnSolve" HorizontalContentAlignment="Center" HorizontalAlignment="Left" Click="btnSolve_Click">Solve</n:NavButton>
            <n:NavButton x:Name="btnLeave" HorizontalContentAlignment="Center" HorizontalAlignment="Right" Grid.Column="1" Command="NavigationCommands.BrowseBack">Leave</n:NavButton>
        </Grid>
        
        
    </Grid>
</Page>
