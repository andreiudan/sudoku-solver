<Page x:Class="SudokuSolver.Pages.Info"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SudokuSolver.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Info">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="85*"/>
            <RowDefinition Height="15*"/>
        </Grid.RowDefinitions>
        
        <!-- Info -->
        <UniformGrid Columns="1" Rows="3">
            <TextBlock Text="Made by: Dan Andreiu"/>
            <TextBlock Text="Date: 10/09/2025"/>
            <TextBlock Text="About: "/>
        </UniformGrid>
        

        <!-- Buttons -->
        <Button Name="btnBack" Command="NavigationCommands.BrowseBack" Grid.Row="1" Margin="0,0,12,0" HorizontalAlignment="Right" VerticalAlignment="Center" Height="50" Width="150" TextBlock.FontSize="18">Back</Button>
    </Grid>
</Page>
