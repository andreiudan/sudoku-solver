<Window x:Class="SudokuSolver.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SudokuSolver"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <TextBlock Name="tbTitle" Text="Sudoku" VerticalAlignment="Top" HorizontalAlignment="Center" FontSize="32" FontWeight="Bold" Margin="32"></TextBlock>
        <UniformGrid Height="NaN" Margin="20,20,20,20" HorizontalAlignment="Center" VerticalAlignment="Center" Columns="1" Rows="0">
            <Button Width="200" Height="50" />
            <Button Width="200" Height="50" Margin="0 20 0 20"/>
        </UniformGrid>
    </Grid>
</Window>
